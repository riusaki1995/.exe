{
  "name": "panel-elarbol",
  "version": "1.0.70",
  "description": "Panel interactivo para streamers",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "start-pc": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "Agencia ELArbol",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@streamerbot/client": "^1.12.2",
    "adm-zip": "^0.5.17",
    "axios": "^1.14.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "multer": "^2.1.1",
    "obs-websocket-js": "^5.0.6",
    "pynput": "^0.4.0",
    "rcon-client": "^4.2.5",
    "socket.io": "^4.8.3",
    "tiktok-live-connector": "^2.1.1-beta1"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.agenciaelarbol.panelpro",
    "productName": "Panel TikTok PRO",
    "npmRebuild": false,
    "extraFiles": [
      "python-bin"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
